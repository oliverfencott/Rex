{
  "name": "rex",
  "version": "2.0.0",
  "description": "Rex is a free open source tool designed to be used with the game Metal Gear Solid on the original Playstation. It allows the user to extract Dir and Dar archive files packaged with the game",
  "main": "dist/main.js",
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node test/test-roundtrip.mjs",
    "release": "npm version major && git push --follow-tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oliverfencott/Rex.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/oliverfencott/Rex/issues"
  },
  "homepage": "https://github.com/oliverfencott/Rex#readme",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.8.3"
  }
}
