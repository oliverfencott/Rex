{
  "compilerOptions": {
    "module": "commonjs",
    "target": "esnext",
    "checkJs": false,
    "experimentalDecorators": false,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strict": true,
    "sourceMap": false,
    "noEmit": false,
    "outDir": "dist",
    "types": [
      "node"
    ]
  },
  "include": [
    "main.ts"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/*"
  ]
}